# Copy this file to ".env" and fill in your values. NEVER commit the real .env.
#
# EASIEST PATH (no app registration): set ONLY DATAVERSE_URL below, then run:
#     python provision_gtos_dataverse.py --interactive
# You sign in as yourself; TENANT_ID/CLIENT_ID/CLIENT_SECRET are NOT needed.
#
# The URL is what you see in the browser address bar of make.powerapps /
# Dataverse, e.g. https://org331e3f60.crm.dynamics.com
DATAVERSE_URL=https://YOUR_ORG.crm.dynamics.com

# --- App-only auth (only if you use client credentials instead of --interactive) ---
TENANT_ID=00000000-0000-0000-0000-000000000000
CLIENT_ID=00000000-0000-0000-0000-000000000000
CLIENT_SECRET=your-app-registration-secret

# Optional: add created objects to an existing unmanaged solution
SOLUTION_NAME=
