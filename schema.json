        { "schemaName": "Preconditions", "displayName": "Preconditions", "type": "memo" },
        { "schemaName": "Postconditions", "displayName": "Postconditions", "type": "memo" },
        { "schemaName": "EvidenceRequirements", "displayName": "Evidence Requirements", "type": "memo" },
        { "schemaName": "Status", "displayName": "Status", "type": "choice",
          "options": ["Designed", "Running", "Verified", "Rejected"] }
      ]
    },
    {
      "schemaName": "Governance",
      "displayName": "GTOS Governance",
      "displayCollectionName": "GTOS Governance Records",
