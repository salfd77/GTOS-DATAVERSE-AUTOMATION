      "displayName": "GTOS State",
      "displayCollectionName": "GTOS States",
      "description": "A durable, evidenced snapshot in the State Graph (04_STATE_PHYSICS).",
      "primaryName": { "schemaName": "Name", "displayName": "State Name", "maxLength": 200 },
      "columns": [
        { "schemaName": "LifecycleStage", "displayName": "Lifecycle Stage", "type": "choice",
          "options": ["Idea", "Requirements", "Architecture", "Build", "Verify", "Deliver", "Learn"] },
        { "schemaName": "Status", "displayName": "Status", "type": "choice",
          "options": ["Active", "Superseded", "RolledBack"] },
        { "schemaName": "EntryConditions", "displayName": "Entry Conditions", "type": "memo" },
        { "schemaName": "ExitConditions", "displayName": "Exit Conditions", "type": "memo" },
        { "schemaName": "EvidenceBundle", "displayName": "Evidence Bundle", "type": "memo" }
      ]
    },
    {
      "schemaName": "Knowledge",
      "displayName": "GTOS Knowledge",
      "displayCollectionName": "GTOS Knowledge",
      "description": "A single typed knowledge entity (02_KNOWLEDGE_PHYSICS).",
      "primaryName": { "schemaName": "Name", "displayName": "Title", "maxLength": 200 },
      "columns": [
        { "schemaName": "KnowledgeType", "displayName": "Knowledge Type", "type": "choice",
          "options": ["Fact", "Assumption", "Hypothesis", "Decision", "Lesson"] },
        { "schemaName": "Statement", "displayName": "Statement", "type": "memo" },
        { "schemaName": "Evidence", "displayName": "Evidence", "type": "memo" },
