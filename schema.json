      "primaryName": { "schemaName": "Name", "displayName": "Record Name", "maxLength": 200 },
      "columns": [
        { "schemaName": "AuthorityScope", "displayName": "Authority Scope", "type": "string", "maxLength": 400 },
        { "schemaName": "Ownership", "displayName": "Ownership", "type": "string", "maxLength": 200 },
        { "schemaName": "ApprovalStatus", "displayName": "Approval Status", "type": "choice",
          "options": ["Pending", "Approved", "Rejected"] },
        { "schemaName": "ApprovedBy", "displayName": "Approved By", "type": "string", "maxLength": 200 },
        { "schemaName": "Evidence", "displayName": "Evidence", "type": "memo" }
      ]
    },
    {
      "schemaName": "Audit",
      "displayName": "GTOS Audit",
      "displayCollectionName": "GTOS Audit Trail",
