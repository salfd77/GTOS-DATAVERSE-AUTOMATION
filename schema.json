      "primaryName": { "schemaName": "Name", "displayName": "Finding Title", "maxLength": 200 },
      "columns": [
        { "schemaName": "Description", "displayName": "Description", "type": "memo" },
        { "schemaName": "Severity", "displayName": "Severity", "type": "choice",
